@{
    ViewData["Title"] = "Registrar Equipo";
}

<div class="max-w-2xl mx-auto px-4 py-8">

    <!-- Encabezado con navegación hacia atrás -->
    <div class="mb-8">
        <a href="@Url.Action("Index", "MiPanel")"
           class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-indigo-600 font-medium transition-colors mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Volver a mi panel
        </a>
        <h1 class="text-2xl font-bold text-slate-900">Registrar nuevo equipo</h1>
        <p class="text-sm text-slate-500 mt-1">
            Agrega los datos del equipo que deseas registrar en el sistema.
        </p>
    </div>

    <!-- Formulario -->
    <form asp-action="RegistrarEquipo" asp-controller="MiPanel" method="post"
          enctype="multipart/form-data" id="form-registro"
          class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">

        @Html.AntiForgeryToken()

        <!-- Preview de foto -->
        <div class="relative h-52 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center cursor-pointer overflow-hidden"
             onclick="document.getElementById('foto').click()">
            <img id="preview-foto" src="" alt=""
                 class="absolute inset-0 w-full h-full object-cover hidden"/>
            <div id="placeholder-foto" class="flex flex-col items-center gap-3 text-slate-400 select-none">
                <div class="w-14 h-14 bg-white/60 rounded-2xl flex items-center justify-center backdrop-blur-sm border border-white/80 shadow-sm">
                    <svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div class="text-center">
                    <p class="font-semibold text-sm text-slate-600">Haz clic para subir una foto</p>
                    <p class="text-xs text-slate-400 mt-0.5">JPG, PNG o WEBP · Máx. 5MB</p>
                </div>
            </div>
            <input type="file" id="foto" name="foto" accept="image/*" class="hidden">
        </div>

        <div class="p-6 space-y-5">
            <!-- Tipo de elemento -->
            <div>
                <label for="tipoElemento" class="block text-sm font-semibold text-slate-700 mb-2">
                    Tipo de elemento <span class="text-red-500">*</span>
                </label>
                <select id="tipoElemento" name="tipoElemento" required
                        class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all bg-white text-slate-800">
                    <option value="">Seleccione un tipo...</option>
                    <option value="Laptop">💻 Laptop / Portátil</option>
                    <option value="Tablet">📱 Tablet</option>
                    <option value="Monitor">🖥️ Monitor</option>
                    <option value="Cámara">📷 Cámara</option>
                    <option value="Herramienta">🔧 Herramienta</option>
                    <option value="Otro">📦 Otro</option>
                </select>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Marca -->
                <div>
                    <label for="idMarca" class="block text-sm font-semibold text-slate-700 mb-2">Marca</label>
                    <select id="idMarca" name="idMarca"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all bg-white text-slate-800">
                        <option value="">Sin marca / Otra</option>
                        @foreach (var m in (IEnumerable<SelectListItem>)ViewBag.Marcas)
                        {
                            <option value="@m.Value">@m.Text</option>
                        }
                    </select>
                </div>

                <!-- Serial -->
                <div>
                    <label for="serial" class="block text-sm font-semibold text-slate-700 mb-2">Número de Serie</label>
                    <input id="serial" name="serial" type="text" placeholder="Ej: SN12345678"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all placeholder:text-slate-300"/>
                </div>
            </div>

            <!-- Botón de envío -->
            <button type="submit" id="btn-submit"
                    class="w-full flex items-center justify-center gap-2 bg-indigo-600 text-white font-bold py-3.5 rounded-xl shadow-lg shadow-indigo-600/30 hover:bg-indigo-500 hover:-translate-y-0.5 active:scale-[0.98] transition-all mt-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Guardar equipo
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    // Preview de foto al seleccionar
    document.getElementById('foto').addEventListener('change', function () {
        const file = this.files[0];
        if (!file) return;

        if (file.size > 5 * 1024 * 1024) {
            Swal.fire({
                title: 'Archivo muy pesado',
                text: 'La imagen no debe superar 5MB.',
                icon: 'warning',
                confirmButtonColor: '#4f46e5',
                customClass: { popup: 'rounded-2xl', confirmButton: 'rounded-xl font-semibold' }
            });
            this.value = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = e => {
            const preview = document.getElementById('preview-foto');
            const placeholder = document.getElementById('placeholder-foto');
            preview.src = e.target.result;
            preview.classList.remove('hidden');
            placeholder.classList.add('hidden');
        };
        reader.readAsDataURL(file);
    });

    // Deshabilitar botón al enviar para evitar doble submit
    document.getElementById('form-registro').addEventListener('submit', function () {
        const btn = document.getElementById('btn-submit');
        btn.disabled = true;
        btn.innerHTML = `<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg> Guardando...`;
    });
</script>
}
