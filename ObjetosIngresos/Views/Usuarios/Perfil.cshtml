@model ObjetosIngresos.Models.Usuario

@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <span class="fs-1 fw-bold">
                                    @(string.IsNullOrEmpty(Model?.Nombres) ? "U" : Model.Nombres.Substring(0, 1))
                                </span>
                            </div>
                        </div>
                        <div class="ms-4">
                            <h2 class="mb-0 fw-bold">@(Model?.Nombres ?? "Usuario") @(Model?.Apellidos ?? "")</h2>
                            <span class="badge bg-info text-dark">@Model.IdTipoUsuarioNavigation?.Descripcion</span>
                            <p class="text-muted mb-0 mt-1"><i class="bi bi-geo-alt-fill"></i> @Model.IdSedePrincipalNavigation?.NombreSede</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white fw-bold">Datos Personales</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="text-muted small d-block">Número de Documento</label>
                                <span class="fw-bold">@Model.Documento</span>
                            </div>
                            <div class="mb-3">
                                <label class="text-muted small d-block">Ficha / Dependencia</label>
                                <span class="fw-bold">@Model.Ficha</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white fw-bold">Seguridad del Sistema</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="text-muted small d-block">ID de Vinculación (Firebase)</label>
                                <code class="small text-break">@Model.FirebaseUid</code>
                            </div>
                            <div class="d-grid mt-3">
                                <button class="btn btn-outline-danger btn-sm" onclick="cerrarSesion()">
                                    <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 text-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-link text-decoration-none">
                    <i class="bi bi-arrow-left"></i> Ir al Panel Principal
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/auth-login.js"></script>

}