@model string
@{
    ViewData["Title"] = "Configurar Seguridad";
    var documento = Model;
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden transform transition-all">
        <div class="p-8 sm:p-10">

            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-emerald-500 text-white rounded-full inline-flex items-center justify-center mb-4 shadow-md shadow-emerald-200">
                    <i class="bi bi-shield-lock-fill text-2xl"></i>
                </div>
                <h2 class="text-2xl font-bold text-gray-800 tracking-tight">¡Cuenta Creada!</h2>
                <p class="text-sm text-gray-500 mt-2">Por seguridad, ahora debes crear una contraseña personal.</p>
            </div>

            <div id="registroForm" class="space-y-5">

                <input type="hidden" id="identificadorUsuario" value="@documento" />

                <div class="relative">
                    <input type="password" id="newPass" required placeholder=" "
                           class="block w-full px-4 pt-6 pb-2 text-gray-900 bg-gray-50 rounded-xl border border-gray-200 appearance-none focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent focus:bg-white peer transition-all text-sm" />
                    <label for="newPass"
                           class="absolute text-sm text-gray-400 duration-300 transform -translate-y-3 scale-75 top-4 z-10 origin-[0] left-4 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-3 peer-focus:text-emerald-600 pointer-events-none">
                        Nueva Contraseña
                    </label>
                </div>

                <div class="relative">
                    <input type="password" id="confirmPass" required placeholder=" "
                           class="block w-full px-4 pt-6 pb-2 text-gray-900 bg-gray-50 rounded-xl border border-gray-200 appearance-none focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent focus:bg-white peer transition-all text-sm" />
                    <label for="confirmPass"
                           class="absolute text-sm text-gray-400 duration-300 transform -translate-y-3 scale-75 top-4 z-10 origin-[0] left-4 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-3 peer-focus:text-emerald-600 pointer-events-none">
                        Confirmar Contraseña
                    </label>
                </div>

                <div class="flex items-center p-3 text-xs text-blue-800 bg-blue-50 rounded-xl border border-blue-100">
                    <i class="bi bi-info-circle-fill text-sm mr-2 flex-shrink-0"></i>
                    <span>Usa al menos 6 caracteres.</span>
                </div>

                <button type="button" id="btnActualizar" onclick="despacharRegistro()"
                        class="w-full py-4 px-6 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl shadow-lg shadow-emerald-200 hover:shadow-xl transition-all duration-200 flex items-center justify-center space-x-2 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">
                    <span id="btnText">Guardar y Finalizar</span>
                    <span id="btnSpinner" class="hidden animate-spin h-5 w-5 border-2 border-white border-t-transparent rounded-full" role="status"></span>
                </button>
            </div>

            <div id="mensajeError" class="hidden mt-4 p-3 text-sm text-red-800 bg-red-50 rounded-xl border border-red-100 font-bold"></div>
        </div>
    </div>
</div>
<div id="modalExito" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-slate-900/60 backdrop-blur-sm transition-all duration-300 opacity-0">
    <div class="bg-white rounded-3xl p-8 max-w-sm w-full mx-4 shadow-2xl border border-slate-100 text-center transform scale-95 transition-transform duration-300">

        <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-emerald-50 text-emerald-500 mb-6 shadow-inner">
            <i class="bi bi-check-circle-fill text-3xl animate-bounce"></i>
        </div>

        <h3 class="text-xl font-bold text-slate-800 mb-2">¡Todo listo!</h3>
        <p class="text-sm text-slate-500 mb-6">Tu contraseña se ha configurado con éxito. Bienvenido al sistema.</p>

        <button type="button" onclick="redirigirAlPerfil()"
                class="w-full bg-slate-900 hover:bg-slate-800 text-white font-semibold py-3 px-4 rounded-xl transition-all duration-200 shadow-lg shadow-slate-900/20 active:scale-[0.98]">
            Comenzar
        </button>
    </div>
</div>
@section Scripts {
    <script>
        window.FirebaseConfigServidor = @Html.Raw(Json.Serialize(ViewBag.FirebaseConfig));
    </script>

    <script type="module" src="~/js/auth-login-v2.js?v=@DateTime.Now.Ticks"></script>

}