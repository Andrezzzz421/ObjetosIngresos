@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout"; 
    ViewData["HideNavbar"] = true; 
}

<div class="min-h-screen flex items-center justify-center bg-gray-100 px-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-2xl p-8">
        <div class="text-center mb-8">
            <div class="bg-blue-600 text-white rounded-full inline-flex items-center justify-center w-16 h-16 mb-4 shadow-lg">
                <i class="bi bi-person-fill text-2xl"></i>
            </div>
            <h2 class="text-3xl font-extrabold text-gray-900">Bienvenido</h2>
            <p class="text-gray-500 mt-2">Ingresa tus datos para continuar</p>
        </div>

        <div id="loginForm" class="space-y-6">
            <div>
                <label for="documento" class="block text-sm font-medium text-gray-700 mb-1">Número de Documento</label>
                <input type="text" id="documento" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="123456789" required>
            </div>

            <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
                <input type="password" id="password" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="••••••••" required>
            </div>

            <div class="flex items-center">
                <input type="checkbox" id="rememberMe" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                <label for="rememberMe" class="ml-2 block text-sm text-gray-600">Recordarme en este equipo</label>
            </div>

            <button type="button" id="btnLogin" onclick="procesarLogin()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl shadow-md transform active:scale-95 transition duration-150">
                <span id="btnText">Entrar al Sistema</span>
                <span id="btnSpinner" class="hidden animate-spin h-5 w-5 border-2 border-white border-t-transparent rounded-full mx-auto"></span>
            </button>
        </div>

        <div id="mensajeError" class="hidden mt-4 p-3 bg-red-100 text-red-700 rounded-lg text-sm text-center"></div>

        <div class="text-center mt-6">
            <p class="text-sm text-gray-500">¿Primera vez aquí? <br> <span class="font-semibold">Usa tu documento como contraseña inicial.</span></p>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/auth-login.js"></script>
}