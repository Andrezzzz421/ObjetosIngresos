@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout"; 
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card border-0 shadow-lg mt-5">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
                            <i class="bi bi-person-fill fs-2"></i>
                        </div>
                        <h2 class="fw-bold">Bienvenido</h2>
                        <p class="text-muted">Ingresa tus datos para continuar</p>
                    </div>

                    <div id="loginForm">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="documento" placeholder="123456789" required>
                            <label for="documento">Número de Documento</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input type="password" class="form-control" id="password" placeholder="Contraseña" required>
                            <label for="password">Contraseña</label>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe">
                            <label class="form-check-label small" for="rememberMe">Recordarme en este equipo</label>
                        </div>

                        <button type="button" id="btnLogin" class="btn btn-primary w-100 py-3 fw-bold shadow-sm" onclick="procesarLogin()">
                            <span id="btnText">Entrar al Sistema</span>
                            <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                        </button>
                    </div>

                    <div id="mensajeError" class="alert alert-danger mt-3 d-none" role="alert">
                    </div>

                    <div class="text-center mt-4">
                        <p class="small text-muted">¿Primera vez aquí? <br> Usa tu documento como contraseña inicial.</p>
                    </div>
                </div>
            </div>

            <p class="text-center text-muted mt-4 small">&copy; 2026 Sistema de Gestión de Ingresos</p>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/auth-login.js"></script>
}