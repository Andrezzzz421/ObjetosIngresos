@model string
<div class="min-h-screen flex items-center justify-center bg-slate-50 px-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl p-8 border border-slate-100 text-center">
        <h2 class="text-2xl font-bold text-slate-800">Verifica tu correo</h2>
        <p class="text-slate-500 text-sm mt-2 mb-8">Introduce el código enviado a <b>@Model</b></p>

        <form asp-controller="Auth" asp-action="ValidarCodigo" method="post" class="space-y-6">
            <input type="hidden" name="email" value="@Model" />

            <input type="text" name="codigo" maxlength="6" required placeholder="000000"
                   class="w-full text-center tracking-[0.5em] text-3xl font-mono font-bold px-4 py-4 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none">

            @if (ViewBag.Error != null)
            {
                <div class="p-3 bg-red-50 text-red-700 text-xs rounded-lg">@ViewBag.Error</div>
            }

            <button type="submit" class="w-full bg-indigo-600 text-white font-bold py-3 rounded-xl hover:bg-indigo-700 transition">
                Verificar Código
            </button>
        </form>
    </div>
</div>