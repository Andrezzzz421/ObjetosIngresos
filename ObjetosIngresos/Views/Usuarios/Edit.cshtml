@model ObjetosIngresos.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="min-h-screen bg-slate-50 p-4 lg:p-8 flex items-center justify-center">
    <div class="w-full max-w-2xl bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">

        <div class="bg-gradient-to-r from-indigo-600 to-blue-500 p-8 text-white">
            <h2 class="text-3xl font-bold">Editar Perfil</h2>
            <p class="text-indigo-100 mt-2">Modifica la información detallada del usuario en el sistema.</p>
        </div>

        <form asp-action="Edit" class="p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="p-4 bg-red-50 border-l-4 border-red-500 text-red-700 text-sm rounded-r-lg mb-6"></div>

            <input type="hidden" asp-for="IdUsuario" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="Nombres" class="text-sm font-semibold text-slate-700 ml-1"></label>
                    <input asp-for="Nombres" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" />
                    <span asp-validation-for="Nombres" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Apellidos" class="text-sm font-semibold text-slate-700 ml-1"></label>
                    <input asp-for="Apellidos" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" />
                    <span asp-validation-for="Apellidos" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="Documento" class="text-sm font-semibold text-slate-700 ml-1"></label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" /></svg>
                        </span>
                        <input asp-for="Documento" class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 outline-none transition-all" />
                    </div>
                    <span asp-validation-for="Documento" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Ficha" class="text-sm font-semibold text-slate-700 ml-1"></label>
                    <input asp-for="Ficha" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all" placeholder="N/A" />
                    <span asp-validation-for="Ficha" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="space-y-2">
                <label asp-for="FirebaseUid" class="text-sm font-semibold text-slate-700 ml-1"></label>
                <input asp-for="FirebaseUid" readonly class="w-full px-4 py-3 rounded-xl border border-slate-100 bg-slate-50 text-slate-500 font-mono text-sm cursor-not-allowed" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="IdTipoUsuario" class="text-sm font-semibold text-slate-700 ml-1">Rol en el Sistema</label>
                    <select asp-for="IdTipoUsuario" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none appearance-none bg-[url('https://cdn-icons-png.flaticon.com/512/60/60995.png')] bg-[length:12px] bg-[right_1rem_center] bg-no-repeat transition-all" asp-items="ViewBag.IdTipoUsuario"></select>
                </div>

                <div class="space-y-2">
                    <label asp-for="IdSedePrincipal" class="text-sm font-semibold text-slate-700 ml-1">Sede Asignada</label>
                    <select asp-for="IdSedePrincipal" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none appearance-none bg-[url('https://cdn-icons-png.flaticon.com/512/60/60995.png')] bg-[length:12px] bg-[right_1rem_center] bg-no-repeat transition-all" asp-items="ViewBag.IdSedePrincipal"></select>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-slate-100">
                <button type="submit" class="flex-1 bg-slate-900 text-white font-bold py-4 rounded-xl shadow-lg hover:bg-slate-800 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    Guardar Cambios
                </button>
                <a asp-action="Index" class="flex-1 bg-white border border-slate-200 text-slate-600 font-bold py-4 rounded-xl text-center hover:bg-slate-50 transition-all">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}