@model ObjetosIngresos.Models.Usuario

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="min-h-screen bg-slate-50 p-4 lg:p-8 flex items-center justify-center">
    <div class="w-full max-w-2xl bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">

        <div class="bg-slate-900 p-8 text-white flex items-center justify-between">
            <div>
                <h2 class="text-3xl font-bold">Registrar Usuario</h2>
                <p class="text-slate-400 mt-2">Ingresa los datos para dar de alta a un nuevo integrante.</p>
            </div>
            <div class="hidden sm:block bg-white/10 p-4 rounded-2xl backdrop-blur-md">
                <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </
                </svg>
            </div>
        </div>

        <form asp-action="Create" class="p-8 space-y-6">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="Nombres" class="text-sm font-semibold text-slate-700 ml-1">Nombres</label>
                    <input asp-for="Nombres" placeholder="Ej. Juan Carlos"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all placeholder:text-slate-300" />
                    <span asp-validation-for="Nombres" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Apellidos" class="text-sm font-semibold text-slate-700 ml-1">Apellidos</label>
                    <input asp-for="Apellidos" placeholder="Ej. Pérez"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all placeholder:text-slate-300" />
                    <span asp-validation-for="Apellidos" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="Documento" class="text-sm font-semibold text-slate-700 ml-1">Número de Documento</label>
                    <input asp-for="Documento" placeholder="123456789"
                           class="input-solo-numeros w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all" />
                    <span asp-validation-for="Documento" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Ficha" class="text-sm font-semibold text-slate-700 ml-1">Número de Ficha (Opcional)</label>
                    <input asp-for="Ficha" placeholder="267... o N/A"
                           class="input-solo-numeros w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all" />
                    <span asp-validation-for="Ficha" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="space-y-2">
                <label asp-for="Correo" class="text-sm font-semibold text-slate-700 ml-1">Correo Electrónico</label>
                <div class="relative">
                    <input asp-for="Correo" type="email" placeholder="ejemplo@correo.com"
                           class="w-full pl-4 pr-10 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all" />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-300">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206" />
                        </svg>
                    </span>
                </div>
                <span asp-validation-for="Correo" class="text-xs text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="IdTipoUsuario" class="text-sm font-semibold text-slate-700 ml-1">Tipo de Usuario</label>
                    <div class="relative">
                        <select asp-for="IdTipoUsuario" class="w-full px-4 py-3 rounded-xl border border-slate-200 appearance-none focus:ring-2 focus:ring-indigo-500 outline-none bg-white transition-all" asp-items="ViewBag.TiposUsuarios"></select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-slate-400">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label asp-for="IdSedePrincipal" class="text-sm font-semibold text-slate-700 ml-1">Sede Principal</label>
                    <div class="relative">
                        <select asp-for="IdSedePrincipal" class="w-full px-4 py-3 rounded-xl border border-slate-200 appearance-none focus:ring-2 focus:ring-indigo-500 outline-none bg-white transition-all" asp-items="ViewBag.Sedes"></select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-slate-400">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-slate-100">
                <button type="submit" class="flex-[2] bg-indigo-600 text-white font-bold py-4 rounded-xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
                    Crear Usuario
                </button>
                <a asp-action="Index" class="flex-1 bg-white border border-slate-200 text-slate-600 font-bold py-4 rounded-xl text-center hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                    Volver
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/GlobalScript.js" asp-append-version="true"></script>

    @if (!ViewData.ModelState.IsValid)
    {
        var errores = ViewData.ModelState.Values
            .SelectMany(v => v.Errors)
            .Select(e => e.ErrorMessage)
            .ToList();

        <div id="validation-errors-carrier" data-errors="@Json.Serialize(errores)" class="hidden"></div>
    }
}