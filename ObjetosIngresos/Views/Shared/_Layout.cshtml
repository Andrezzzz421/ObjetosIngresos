<!DOCTYPE html>
<html lang="es" class="h-full bg-slate-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] | SGI</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="h-full text-slate-800 antialiased flex flex-col md:flex-row overflow-hidden">

    @if (ViewData["HideNavbar"] == null)
    {
        <div class="md:hidden bg-slate-900 text-white h-16 flex items-center justify-between px-4 border-b border-slate-800 shrink-0 z-50">
            <div class="flex items-center gap-2">
                <div class="bg-indigo-600 text-white p-1.5 rounded-lg">
                    <span class="font-black text-lg tracking-tighter">SGI</span>
                </div>
                <span class="font-bold text-sm tracking-tight">Sistema de Gestión</span>
            </div>
            <button id="btn-toggle-sidebar" class="p-2 rounded-lg hover:bg-slate-800 focus:outline-none text-slate-400 hover:text-white transition-colors">
                <i data-lucide="menu" id="icon-menu" class="w-6 h-6"></i>
                <i data-lucide="x" id="icon-close" class="w-6 h-6 hidden"></i>
            </button>
        </div>

        <aside id="sidebar" class="fixed inset-y-0 left-0 transform -translate-x-full md:relative md:translate-x-0 w-64 bg-slate-900 text-slate-300 flex flex-col border-r border-slate-800 z-40 shrink-0 transition-transform duration-300 ease-in-out h-full pt-16 md:pt-0">
            <div class="hidden md:flex h-16 items-center px-6 border-b border-slate-800 gap-3">
                <div class="bg-indigo-600 text-white p-1.5 rounded-lg shadow-md shadow-indigo-600/20">
                    <span class="font-black text-xl tracking-tighter block leading-none">SGI</span>
                </div>
                <div class="flex flex-col">
                    <span class="font-bold text-sm text-white tracking-tight leading-none">Sistema de Gestión</span>
                    <span class="text-[10px] text-slate-500 italic mt-0.5">Objetos e Ingresos</span>
                </div>
            </div>

            <nav class="flex-grow p-4 space-y-1 overflow-y-auto">
                <ul>
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800 hover:text-white font-medium transition-all duration-200 group">
                            <i data-lucide="home" class="w-5 h-5 text-slate-400 group-hover:text-indigo-400 transition-colors"></i>
                            Inicio
                        </a>
                    </li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li>
                            <a asp-controller="Usuarios" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800 hover:text-white font-medium transition-all duration-200 group">
                                <i data-lucide="layout-grid" class="w-5 h-5 text-slate-400 group-hover:text-indigo-400 transition-colors"></i>
                                Servicios
                            </a>
                        </li>

                        <li class="relative">
                            <button id="btn-toggle-catalogos" type="button" class="w-full flex items-center justify-between px-4 py-3 rounded-xl hover:bg-slate-800 hover:text-white font-medium transition-all duration-200 group">
                                <div class="flex items-center gap-3">
                                    <i data-lucide="layout-grid" class="w-5 h-5 text-slate-400 group-hover:text-indigo-400 transition-colors"></i>
                                    <span>Catálogos</span>
                                </div>
                                <i data-lucide="chevron-down" id="icon-chevron-catalogos" class="w-4 h-4 text-slate-400 transition-transform duration-200"></i>
                            </button>

                            <ul id="menu-catalogos" class="hidden pl-11 pr-2 py-1 space-y-1 bg-slate-950/20 rounded-xl mt-1">
                                <li>
                                    <a asp-controller="Catalogos" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm hover:text-white hover:bg-slate-800 transition-colors">
                                        Ver Todo (Inicio)
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="Catalogos" asp-action="CentrosFormacion" class="block px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                                        Centros de Formación
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="Catalogos" asp-action="Marcas" class="block px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                                        Marcas
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="Catalogos" asp-action="Regionales" class="block px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                                        Regionales
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="Catalogos" asp-action="Sedes" class="block px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                                        Sedes
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="Catalogos" asp-action="TiposDetalle" class="block px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                                        Tipos de Detalle
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="Catalogos" asp-action="TiposUsuario" class="block px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                                        Tipos de Usuario
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li>
                            <a asp-controller="Auth" asp-action="Perfil" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800 hover:text-white font-medium transition-all duration-200 group">
                                <i data-lucide="user" class="w-5 h-5 text-slate-400 group-hover:text-indigo-400 transition-colors"></i>
                                Perfil
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Elementos" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800 hover:text-white font-medium transition-all duration-200 group">
                                <i data-lucide="package" class="w-5 h-5 text-slate-400 group-hover:text-indigo-400 transition-colors"></i>
                                Objetos
                            </a>
                        </li>

                    }
                    else
                    {
                        <li class="pt-2 mt-2">
                            <a asp-controller="Auth" asp-action="Login" class="flex items-center justify-center gap-3 px-4 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold shadow-lg shadow-indigo-600/30 transition-all duration-300 hover:-translate-y-0.5 group">
                                <i data-lucide="log-in" class="w-5 h-5 text-indigo-100 group-hover:text-white transition-colors"></i>
                                <span>Iniciar Sesión</span>
                            </a>
                        </li>
                    }

                    <li>
                        <a asp-controller="Home" asp-action="SaberMas" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-800 hover:text-white font-medium transition-all duration-200 group">
                            <i data-lucide="help-circle" class="w-5 h-5 text-slate-400 group-hover:text-indigo-400 transition-colors"></i>
                            Ayuda
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="p-4 border-t border-slate-800 bg-slate-950/40 text-xs space-y-4">
            
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="pt-4 border-t border-slate-800/60">
                        <!-- FORMULARIO PARA CERRAR SESIÓN -->
                        <form id="logout-form" asp-controller="Auth" asp-action="Logout" method="post" class="hidden">
                            @Html.AntiForgeryToken()
                        </form>
                        <button id="btn-logout" type="button" class="w-full flex items-center justify-center gap-3 px-4 py-3 rounded-xl bg-rose-500/10 text-rose-400 hover:bg-rose-500 hover:text-white font-medium transition-all duration-300 shadow-sm focus:outline-none focus:ring-2 focus:ring-rose-500/40 group">
                            <i data-lucide="log-out" class="w-5 h-5 transition-colors"></i>
                            <span class="tracking-wide text-sm font-semibold">Cerrar Sesión</span>
                        </button>
                    </div>
                }

            </div>
        </aside>

        <div id="sidebar-backdrop" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-30 hidden md:hidden transition-opacity"></div>
    }

    <div class="flex-grow flex flex-col min-w-0 overflow-hidden relative">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            var nombreUsuario = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
            var rolUsuario = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Personal";
            var inicial = !string.IsNullOrEmpty(nombreUsuario) ? nombreUsuario.Substring(0, 1).ToUpper() : "U";

            <div class="absolute top-4 right-4 md:top-6 md:right-8 z-[60] hidden lg:flex items-center gap-3 bg-white/80 backdrop-blur-md p-2 pr-4 rounded-2xl shadow-xl border border-slate-200/60 max-w-xs transition-all duration-300 hover:shadow-indigo-100 hover:border-indigo-200 group">
                <div class="relative shrink-0">
                    <div class="w-10 h-10 bg-indigo-600 text-white rounded-xl flex items-center justify-center text-sm font-bold shadow-md shadow-indigo-200/50">
                        @inicial
                    </div>
                    <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-green-500 border-2 border-white rounded-full animate-pulse"></div>
                </div>

                <div class="flex flex-col min-w-0">
                    <span class="text-xs font-bold text-slate-800 truncate leading-tight group-hover:text-indigo-600 transition-colors">
                        @nombreUsuario
                    </span>
                    <span class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider mt-0.5 truncate">
                        @rolUsuario
                    </span>
                </div>

                <div class="ml-2 pl-2 border-l border-slate-200 h-6 flex items-center text-slate-300 group-hover:text-indigo-400 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </div>
            </div>
        }
        <main role="main" class="flex-grow overflow-y-auto p-4 sm:p-6 md:p-8 animate-fade-in">
            <div class="max-w-7xl mx-auto">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/GlobalScript.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnToggle = document.getElementById("btn-toggle-catalogos");
            const menuCatalogos = document.getElementById("menu-catalogos");
            const iconChevron = document.getElementById("icon-chevron-catalogos");

            if (btnToggle && menuCatalogos && iconChevron) {
                btnToggle.addEventListener("click", function () {
                    // Alternar visibilidad del menú
                    menuCatalogos.classList.toggle("hidden");

                    // Rotar el icono de la flecha
                    iconChevron.classList.toggle("rotate-180");
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>