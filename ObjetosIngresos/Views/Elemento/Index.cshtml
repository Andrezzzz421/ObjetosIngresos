@model IEnumerable<ObjetosIngresos.Models.Elemento>
@using ObjetosIngresos.Helpers
@using ObjetosIngresos.Services
@{
    ViewData["Title"] = "Inventario de Elementos";
}

<div class="container mx-auto px-6 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between border-b border-slate-200 pb-5 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-950">Inventario Global de Elementos</h1>
            <p class="text-sm text-slate-600 mt-1">Control de activos ingresados al establecimiento con desglose de periféricos.</p>
        </div>
        <div class="mt-4 sm:mt-0">
            <a href="@Url.Action("Create", "Elementos")" class="inline-flex items-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-600 transition-colors">
                + Registrar Nuevo Equipo
            </a>
        </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 w-24">Imagen</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Equipo Principal</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Dueño / Propietario</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Marca / Serial</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Accesorios Vinculados</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 text-right w-32">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-sm text-center text-slate-400 italic">
                                No se encuentran equipos registrados en el inventario.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr id="fila-elemento-@item.IdElemento" class="hover:bg-slate-50/60 transition-colors">
                                <td class="px-6 py-4">
                                    @{
                                        string cadenaFoto = item.FotoArchivo != null && item.FotoArchivo.Length > 0
                                        ? Url.Action("ObtenerImagen", "Elementos", new { id = item.IdElemento })
                                        : string.Empty;
                                    }

                                    @if (!string.IsNullOrEmpty(cadenaFoto))
                                    {
                                        <img src="@cadenaFoto" alt="Equipo" class="w-12 h-12 object-cover rounded-xl border border-slate-200 shadow-sm" />
                                    }
                                    else
                                    {
                                        <div class="w-12 h-12 rounded-xl bg-slate-100 border border-slate-200 flex items-center justify-center text-[10px] font-bold text-slate-400 uppercase">
                                            S/F
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-sm font-semibold text-slate-900">@item.TipoElemento</span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm font-bold text-slate-800">@(item.IdUsuarioNavigation?.Nombres) @(item.IdUsuarioNavigation?.Apellidos)</div>
                                    <div class="text-xs text-slate-500">@(item.IdUsuarioNavigation?.Documento ?? "Sin documento")</div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-slate-800">@(item.IdMarcaNavigation?.NombreMarca ?? "Sin Marca")</div>
                                    <div class="text-xs font-mono text-slate-400 mt-0.5">@(string.IsNullOrEmpty(item.Serial) ? "N/A" : item.Serial)</div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.DetalleElementos != null && item.DetalleElementos.Any())
                                    {
                                        <div class="flex flex-wrap gap-1.5 max-w-md">
                                            @foreach (var det in item.DetalleElementos)
                                            {
                                                <span class="inline-flex items-center gap-1 rounded-md bg-slate-100 border border-slate-200 px-2 py-1 text-xs font-medium text-slate-700">
                                                    <span class="font-bold text-slate-900">@(det.IdTipoDetalleNavigation?.Nombre ?? "Componente")</span>
                                                </span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-400 italic">Ninguno</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-sm text-right space-x-1">
                                    <a href="@Url.Action("Edit", "Elementos", new { id = item.IdElemento })" class="inline-flex items-center rounded-lg px-2.5 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-100 transition-colors">
                                        Editar
                                    </a>
                                    <button onclick="eliminarElemento(@item.IdElemento)" class="inline-flex items-center rounded-lg px-2.5 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 hover:text-red-700 transition-colors">
                                        Eliminar
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/GlobalScript.js" asp-append-version="true"></script>
}