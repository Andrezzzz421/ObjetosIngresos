@model List<ObjetosIngresos.Models.TiposDetalle>
@{
    ViewData["Title"] = "Administración de Tipos de Detalle";
}

<div class="container mx-auto px-6 py-8">
    <div class="mb-4">
        <a href="@Url.Action("Index", "Catalogos")" class="text-sm font-medium text-slate-500 hover:text-indigo-600 flex items-center gap-1 transition-colors">
            &larr; Volver al Panel de Catálogos
        </a>
    </div>

    <div class="mb-8 border-b border-slate-200 pb-5">
        <h1 class="text-2xl font-bold tracking-tight text-slate-950">Catálogo de Tipos de Detalle</h1>
        <p class="text-sm text-slate-600 mt-1">Configuración y control de periféricos, accesorios y componentes adicionales (Cargadores, ratones, maletines).</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="bg-white border border-slate-200 rounded-2xl p-6 h-fit shadow-sm">
            <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-4">
                Registrar Tipo de Detalle
            </h2>

            <form asp-action="CreateTipoDetalle" asp-controller="Catalogos" method="post" class="space-y-4">
                <div>
                    <label for="Nombre" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
                        Nombre del Periférico o Accesorio
                    </label>
                    <input type="text" id="Nombre" name="Nombre" placeholder="Ej. Cargador, Mouse, Maletín" required
                           class="w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all" />
                </div>

                <button type="submit" class="w-full flex justify-center items-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                    Guardar Registro
                </button>
            </form>
        </div>

        <div class="lg:col-span-2 bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-slate-200 bg-slate-50">
                            @* <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 w-24">ID</th> *@
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Descripción del Accesorio</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 text-right w-32">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="px-6 py-10 text-sm text-center text-slate-400 italic">
                                    No hay tipos de detalle registrados en el sistema.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var tipo in Model)
                            {
                                <tr id="fila-tipo-@tipo.IdTipoDetalle" class="hover:bg-slate-50/60 transition-colors">
                                    @* <td class="px-6 py-4 text-sm font-mono text-slate-400">#@tipo.IdTipoDetalle</td> *@
                                    <td class="px-6 py-4 text-sm font-semibold text-slate-900">@tipo.Nombre</td>
                                    <td class="px-6 py-4 text-sm text-right">
                                        <button onclick="eliminarTipoDetalle(@tipo.IdTipoDetalle)" class="inline-flex items-center rounded-lg px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 hover:text-red-700 transition-colors">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function eliminarTipoDetalle(id) {
            if (confirm("¿Estás seguro de que deseas eliminar este tipo de detalle?")) {
                $.ajax({
                    url: '@Url.Action("DeleteTipoDetalle", "Catalogos")',
                    type: 'POST',
                    data: { id: id },
                    success: function (response) {
                        if (response.success) {
                            let fila = document.getElementById('fila-tipo-' + id);
                            if (fila) {
                                fila.style.opacity = '0';
                                setTimeout(() => fila.remove(), 300);
                            }
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function () {
                        alert("Ocurrió un error de red al intentar eliminar el registro.");
                    }
                });
            }
        }
    </script>
}