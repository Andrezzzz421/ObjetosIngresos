@model List<ObjetosIngresos.Models.Regionale>
@{
    ViewData["Title"] = "Administración de Regionales";
}

<div class="container mx-auto px-6 py-8">
    <div class="mb-4">
        <a href="@Url.Action("Index", "Catalogos")" class="text-sm font-medium text-slate-500 hover:text-indigo-600 flex items-center gap-1 transition-colors">
            &larr; Volver al Panel de Catálogos
        </a>
    </div>

    <div class="mb-8 border-b border-slate-200 pb-5">
        <h1 class="text-2xl font-bold tracking-tight text-slate-950">Catálogo de Regionales</h1>
        <p class="text-sm text-slate-600 mt-1">Configuración y registro de las divisiones territoriales e institucionales del sistema.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="bg-white border border-slate-200 rounded-2xl p-6 h-fit shadow-sm">
            <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-4">
                Registrar Regional
            </h2>

            <form asp-action="CreateRegional" asp-controller="Catalogos" method="post" class="space-y-4">
                <div>
                    <label for="NombreRegional" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
                        Nombre de la Regional
                    </label>
                    <input type="text" id="NombreRegional" name="NombreRegional" placeholder="Ej. Regional Cesar, Regional Bogotá" required
                           class="input-solo-letras w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all" />
                </div>

                <button type="submit" class="w-full flex justify-center items-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                    Guardar Registro
                </button>
            </form>
        </div>

        <div class="lg:col-span-2 bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-slate-200 bg-slate-50">
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Nombre de la Regional</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 text-right w-32">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="2" class="px-6 py-10 text-sm text-center text-slate-400 italic">
                                    No hay regionales registradas en el sistema.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var regional in Model)
                            {
                                <tr id="fila-regional-@regional.IdRegional" class="hover:bg-slate-50/60 transition-colors">
                                    <td class="px-6 py-4 text-sm font-semibold text-slate-900">@regional.NombreRegional</td>
                                    <td class="px-6 py-4 text-sm text-right">
                                        <button onclick="eliminarRegional(@regional.IdRegional)" class="inline-flex items-center rounded-lg px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 hover:text-red-700 transition-colors">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/GlobalScript.js" asp-append-version="true"></script>
}