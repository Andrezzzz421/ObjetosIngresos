@{
    ViewData["Title"] = "Bienvenido";
}

<div class="w-full h-full bg-white text-slate-900">

    <main class="relative py-16 sm:py-24">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 relative z-10">
            <div class="text-center">
                <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-6xl bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-blue-500 py-2 leading-tight">
                    Bienvenido al Sistema de Gestión de Ingreso
                </h1>
                <p class="mt-6 text-lg leading-8 text-slate-600 max-w-2xl mx-auto">
                    Optimiza tus procesos, gestiona tus usuarios y mantén el control total de tu información en un solo lugar con nuestra interfaz intuitiva y segura.
                </p>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                }
            </div>
        </div>

        <div class="absolute inset-0 -z-0 bg-gradient-to-b from-indigo-50/50 to-white opacity-70 pointer-events-none"></div>
    </main>

    <section class="bg-slate-50 py-20 border-t border-slate-100">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="grid grid-cols-1 items-center gap-x-12 gap-y-16 lg:grid-cols-2">

                <div class="order-2 lg:order-1">
                    <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-6">
                        Soporte diseñado para acompañarte
                    </h2>
                    <div class="space-y-4 text-base leading-7 text-slate-600">
                        <p>
                            ¿Necesitas asistencia con el sistema? Nuestro centro de soporte está diseñado para acompañarte en cada paso de tu gestión.
                        </p>
                        <p>
                            Ya sea que tengas dificultades para acceder a tu cuenta, dudas sobre el registro de datos o necesites orientación técnica, estamos aquí para resolverlo.
                        </p>
                        <p class="font-medium text-slate-800">
                            Tu flujo de trabajo es nuestra prioridad.
                        </p>
                    </div>
                    <div class="mt-8">
                        <a asp-controller="Home" asp-action="SaberMas"
                           class="inline-flex items-center gap-2 font-semibold text-indigo-600 hover:text-indigo-500 group">
                            Saber Más
                            <span class="group-hover:translate-x-1 transition-transform" aria-hidden="true">→</span>
                        </a>
                    </div>
                </div>

                <div class="order-1 lg:order-2 flex justify-center">
                    <div class="relative group w-full max-w-sm lg:max-w-md">
                        <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-blue-500 rounded-2xl blur opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>

                        <div class="relative bg-white p-4 rounded-2xl shadow-xl">
                            <img src="~/Soporte.svg" alt="Soporte Técnico"
                                 class="w-full h-auto rounded-lg transform transition duration-500 hover:rotate-1" />
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</div>